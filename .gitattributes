# changelog에는 union 병합 전략을 사용합니다.
# 여러 PR이 동시에 [Unreleased] 끝에 항목을 추가할 때 Git은 충돌 표시 없이 양쪽 라인을 모두 취합니다.
# append-only changelog 파일에 적합합니다.
docs/CHANGELOG.md merge=union

# Documentation image/design assets are binary. Keep GitHub review diffs from
# trying to decode moved binary files as UTF-8.
sources/**/*.ai binary
sources/**/*.gif binary
sources/**/*.ico binary
sources/**/*.jpg binary
sources/**/*.jpeg binary
sources/**/*.png binary
sources/**/*.psd binary
docs/assets/**/*.ai binary
docs/assets/**/*.gif binary
docs/assets/**/*.ico binary
docs/assets/**/*.jpg binary
docs/assets/**/*.jpeg binary
docs/assets/**/*.png binary
docs/assets/**/*.psd binary

# === LF를 강제할 파일 유형(커널/시스템 인터프리터가 직접 소비) ===
# Shell 스크립트(entrypoint.sh, 모든 .sh)
*.sh text eol=lf
*.bash text eol=lf

# Dockerfile(멀티 스테이지 또는 변형 포함)
Dockerfile text eol=lf
Dockerfile.* text eol=lf

# Makefile
Makefile text eol=lf

# 환경변수 파일(shell에서 직접 source할 수 있는 경우)
.env text eol=lf

# === 추가: 바이너리 파일(Git이 줄바꿈/인코딩을 수정하지 않도록 금지) ===
# 인증서, 키 등(있는 경우)
*.pem binary
*.crt binary
*.key binary
*.p12 binary
