# ===================================
# A주 관심종목 지능형 분석 시스템 - 환경변수 설정 템플릿
# 이 파일을 .env로 복사한 뒤 실제 설정을 입력하세요
# ===================================

# 관심종목 목록(쉼표로 구분, 상하이/선전 거래소 코드 지원)
# 상하이: 600xxx, 601xxx, 603xxx
# 선전: 000xxx, 002xxx, 300xxx
STOCK_LIST=600519,300750,002594

# Anspire Open API Keys(여러 개는 쉼표로 구분)
# 발급: https://open.anspire.cn/?share_code=QFBC0FYC
# 더 높은 우선순위의 OpenAI-compatible 소스가 없으면 조건에 따라 이 key를 Anspire LLM 게이트웨이와 뉴스 검색에 재사용합니다.
# 아래 게이트웨이와 모델은 현재 프로젝트 예시입니다. 실제 사용 가능 여부는 Anspire 콘솔과 공식 문서를 확인하세요.
# 예시 게이트웨이: https://open-gateway.anspire.cn/v6
# 예시 모델: Doubao-Seed-2.0-lite(ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-pro로 덮어쓸 수 있음)
# 게이트웨이에 지역/버전 차이가 있으면 ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.ai/v6로 덮어쓸 수 있습니다.
ANSPIRE_API_KEYS=
# ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-lite
# ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.cn/v6
# ANSPIRE_LLM_ENABLED=true
# 데이터 소스 설정
# Tushare Pro Token(선택, https://tushare.pro/weborder/#/login?reg=834638 에서 발급)
TUSHARE_TOKEN=
# TickFlow API Key(선택, A주 시장 리뷰의 지수 보강에 사용. 플랜이 종목 풀 조회를 지원하면 시장 통계도 보강 가능)
# TICKFLOW_API_KEY=

# AlphaSift 종목 선별 연동(기본 꺼짐, 보통 Web의 "종목 선별 켜기" 버튼이 관리)
ALPHASIFT_ENABLED=false
# 스위치 설명:
# - ALPHASIFT_ENABLED는 AlphaSift 종목 선별 흐름에만 영향을 주며 기존 LITELLM_*/LLM_* 설정을 수정/마이그레이션/정리하지 않습니다.
# - 끄거나 되돌릴 때는 ALPHASIFT_ENABLED를 false로 두면 됩니다. 기존 provider/base_url/custom headers와 fallback 의미는 유지됩니다.
# - 호환성 근거(운영 확인용): LiteLLM providers와 OpenAI-compatible 의미 설명은 아래 주석을 참고하세요. 런타임은 기본적으로 requirements.txt에 고정된 litellm 버전을 사용합니다.
ALPHASIFT_INSTALL_SPEC=git+https://github.com/ZhuLinsen/alphasift.git@377049857cc04175dc3cca62121ee41adec6cdb8
# 호환성 설명:
# - ALPHASIFT_INSTALL_SPEC는 /api/v1/alphasift/install을 명시적으로 호출할 때만 사용하며 기존 .env 설정을 자동으로 덮어쓰지 않습니다.
# - 업그레이드 후 새 pin을 쓰려면 기존 `.env`에서 이 변수를 지운 뒤 의존성을 다시 빌드하고 서비스를 재시작하세요. 또는 3770498...로 직접 바꾸고 백엔드를 다시 빌드하세요.
# - .env의 이 필드만 바꾸고 `requirements.txt`와 `src/config.py`를 되돌리지 않으면 allow-list 거부(alphasift_install_spec_not_allowed)가 발생합니다.
# AlphaSift 전체 시장 스냅샷 소스 우선순위. 미설정 시 DSA가 TUSHARE_TOKEN 설정 여부에 따라 자동 주입합니다.
# - TUSHARE_TOKEN 있음: tushare,sina,efinance,akshare_em,em_datacenter
# - TUSHARE_TOKEN 없음: sina,efinance,akshare_em,em_datacenter
# SNAPSHOT_SOURCE_PRIORITY=tushare,sina,efinance,akshare_em,em_datacenter
# 런타임 자동 주입과 맞추려면 이 파일에 고정값을 쓰지 말고 비워두는 것을 권장합니다.
# AlphaSift 최신 버전은 last-good 스냅샷, 일봉 히스토리, 업종/테마 provider 캐시를 지원합니다. DSA 런타임은 기본적으로 data/alphasift 아래의 격리 캐시 디렉터리를 사용합니다.
# 직접 지정하려면 아래 경로를 덮어쓸 수 있습니다. 비워두면 기존 DSA 설정을 바꾸지 않습니다.
# ALPHASIFT_DATA_DIR=data/alphasift
# ALPHASIFT_FALLBACK_SNAPSHOT_PATH=data/alphasift/snapshot.last_good.json
# ALPHASIFT_DAILY_HISTORY_CACHE_DIR=data/alphasift/daily_history
# ALPHASIFT_INDUSTRY_PROVIDER_CACHE_DIR=data/alphasift/industry_provider_cache
# AlphaSift 업종/테마 provider는 기본 꺼짐입니다. akshare를 켜면 theme_heat, 업종 열기, LLM 컨텍스트에 더 많은 섹터 정보를 제공할 수 있습니다.
# INDUSTRY_PROVIDER=none
# INDUSTRY_PROVIDER_MAX_BOARDS=80
# 단일 LLM 요청 제한 시간(초). AlphaSift 종목 선별은 DSA의 이 설정을 재사용하며, 시간 초과 시 비 LLM 정렬 결과로 낮춰 반환합니다.
# LLM_TIMEOUT_SEC=60
# AlphaSift LLM 재정렬 요청 출력 상한. AlphaSift 종목 선별 재정렬에만 영향을 주며 기본값은 2048입니다.
# LLM_MAX_TOKENS=2048

# Finnhub(선택, 미국 주식 데이터 소스, 무료 tier 60 calls/min)
# 발급: https://finnhub.io/register
# FINNHUB_API_KEY=

# AlphaVantage(선택, 미국 주식 데이터 소스, 무료 tier 25 calls/day)
# 발급: https://www.alphavantage.co/support/#api-key
# ALPHAVANTAGE_API_KEY=

# Longbridge OpenAPI(선택, 미국/홍콩 주식의 거래량 비율, 회전율, PE 등 필드 보완)
# https://open.longbridge.com/ 에서 발급
# OAuth 2.0(권장): 먼저 scripts/generate_longbridge_oauth_token.py를 실행해 로컬 SDK token 캐시를 생성하세요.
# client_id는 LONGBRIDGE_OAUTH_CLIENT_ID를 우선 사용합니다. 비어 있고 Legacy Access Token도 없으면 LONGBRIDGE_APP_KEY를 호환 사용합니다.
# GitHub Actions / Docker에서는 token 캐시 파일을 base64로 인코딩해 LONGBRIDGE_OAUTH_TOKEN_CACHE_B64에 넣을 수 있습니다.
# LONGBRIDGE_OAUTH_CLIENT_ID=
# LONGBRIDGE_OAUTH_TOKEN_CACHE_B64=
# Legacy API Key(기존 계정 호환, Access Token은 OAuth access token이 아님)
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=
# static_info 프로세스 내부 캐시 시간(초), 기본값 86400. 0=매 요청마다 가져오기
# LONGBRIDGE_STATIC_INFO_TTL_SECONDS=86400
# 연결 종료류 예외 후 쿨다운 시간(초), 기본값 15. 쿨다운 중에는 Longbridge를 임시로 건너뛰어 요청 단위의 잦은 재연결을 피합니다.
# LONGBRIDGE_CONNECTION_COOLDOWN_SECONDS=15
# Longbridge SDK 언어는 REPORT_LANGUAGE(zh/en)와 일치합니다. SDK 로그는 LOG_DIR/longbridge_sdk.log에 기록됩니다.
# 접속 엔드포인트(REPORT_LANGUAGE와 무관, 비워두면 아래 기본값 사용):
# LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com
# LONGBRIDGE_QUOTE_WS_URL=wss://openapi-quote.longbridge.com/v2
# LONGBRIDGE_TRADE_WS_URL=wss://openapi-trade.longbridge.com/v2
# LONGBRIDGE_REGION=hk
# 접속 엔드포인트 덮어쓰기. SDK 내부는 LONGPORT_REGION(BRIDGE 없음)으로 자동 선택하며,
# 코드는 LONGBRIDGE_REGION -> LONGPORT_REGION을 자동 동기화합니다.
# hk → *.longbridge.com  |  cn → *.longbridge.cn
# 기타 항목: https://open.longbridge.com/zh-CN/docs/getting-started#environment-variables
# 야간장 시세 true/false, 기본 false
# LONGBRIDGE_ENABLE_OVERNIGHT=false
# K라인 푸시는 realtime 또는 confirmed, 기본 realtime
# LONGBRIDGE_PUSH_CANDLESTICK_MODE=realtime
# 연결 시 시세 패킷을 출력할지 여부(README / full-guide와 동일: 미설정 시 앱 기본값은 꺼짐, false와 같음)
# 1 / true / yes로 설정하면 SDK 상세 시세 패킷 로그를 켭니다(Longbridge 연결 디버깅용).
# LONGBRIDGE_PRINT_QUOTE_PACKAGES=false

# 종목 자동완성 인덱스 원격 업데이트(기본 켜짐, GitHub 접근 불가 시 로컬 내장 인덱스로 자동 낮춤)
STOCK_INDEX_REMOTE_UPDATE_ENABLED=true

# ===================================
# AI 모델 설정
# ===================================
# 전체 설명: docs/LLM_CONFIG_GUIDE.md
#
# [빠른 시작] API Key 하나만 입력하면 실행되며, 시스템이 모델을 자동 인식합니다.
#   Anspire Open(모델+검색 통합) -> ANSPIRE_API_KEYS 입력
#   Gemini(무료 한도) -> GEMINI_API_KEY 입력
#   DeepSeek(가성비 높음) -> DEEPSEEK_API_KEY 입력
#   AIHubmix(통합 플랫폼) -> AIHUBMIX_KEY 입력
#
# [고급] 다중 모델 / 다중 플랫폼 fallback이 필요하면 아래 "다중 채널"을 설정하거나 Web 설정 화면에서 시각적으로 관리하세요.
# ===================================

# 생성 백엔드(Phase 1은 litellm만 지원)
# litellm이 아닌 값은 설정 오류로 처리되며 LiteLLM으로 조용히 되돌리지 않습니다.
GENERATION_BACKEND=litellm
# 백엔드 레벨 fallback. litellm -> litellm은 no-op으로 해석되며, 모델 fallback은 여전히 LiteLLM 설정이 담당합니다.
GENERATION_FALLBACK_BACKEND=litellm
# Agent Chat 백엔드. Phase 1에서 auto는 기존 LiteLLM tool-calling 백엔드와 같습니다.
AGENT_GENERATION_BACKEND=auto

# --- API Key(하나만 입력해도 됨) ---

# Gemini(https://aistudio.google.com)
GEMINI_API_KEY=
# 다중 Key 부하 분산: GEMINI_API_KEYS=key1,key2,key3

# DeepSeek(https://platform.deepseek.com)
# 호환 기본값: DEEPSEEK_API_KEY만 입력하면 여전히 deepseek-chat을 사용하며, 로그에서 deepseek-v4-flash로 마이그레이션하라고 안내합니다.
# DEEPSEEK_API_KEY=

# AIHubmix 통합(https://aihubmix.com/?aff=CfMq)
# Key 하나로 GPT/Claude/Gemini/GLM/Qwen 등 모델을 사용합니다.
# AIHUBMIX_KEY=

# Anthropic Claude(https://console.anthropic.com)
# ANTHROPIC_API_KEY=

# OpenAI / 호환 API
# OPENAI_API_KEY=
# OPENAI_BASE_URL=                     # 서드파티 API 주소(중계/프록시), 비워두면 공식 주소 사용

# Ollama 로컬 모델(API Key 불필요, 권장)
# OLLAMA_API_BASE=http://localhost:11434
# LITELLM_MODEL=ollama/qwen3:8b
#
# 또는 채널 모드 사용:
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b

# 샘플링 온도(0.0-2.0, 기본 0.7. 0은 가장 결정적, 2는 가장 무작위)
# 엄격한 temperature 호환 근거:
# - Moonshot API / 모델 문서: https://platform.kimi.ai/docs/guide/kimi-k2-6-quickstart
# - Moonshot 공식 모델 카드(평가 기본 temperature = 1.0): https://huggingface.co/moonshotai/Kimi-K2.6
# - OpenAI Chat Completions 명세: https://platform.openai.com/docs/api-reference/chat/create
# - LiteLLM OpenAI-Compatible 명세: https://docs.litellm.ai/docs/providers/openai_compatible
# 현재 저장소 런타임 의존성 제약: litellm>=1.80.10,!=1.82.7,!=1.82.8,<2.0.0(PyPI 사고 버전 명시 제외, requirements.txt 참고).
# 따라서 kimi-k2.6은 자동으로 1.0/0.6을 사용합니다. GPT-5 / o 계열 등 기본 온도 모델은 API 거부를 피하기 위해 temperature를 생략합니다.
# 호환 플랫폼이 명확한 파라미터 미지원 오류를 반환하면 런타임은 현재 요청 안에서 파라미터를 수정하고 한 번 재시도합니다. 성공 전략은 프로세스 내부 캐시에만 저장됩니다.
# top_p, presence_penalty, frequency_penalty, seed가 "지원하지 않는 파라미터"를 반환해도 같은 방식으로 현재 요청 단위 수정과 재시도가 발생합니다(LLM_TEMPERATURE는 변경하지 않음).
# 다른 모델과 fallback은 계속 사용자가 설정한 LLM_TEMPERATURE를 사용합니다.
# Web 설정 화면 / 데스크톱 가져오기는 LLM_TEMPERATURE를 조용히 비우거나 바꾸지 않습니다. 실제 요청 직전에만 모델 파라미터를 임시 조정합니다.
# 주 모델을 일반 모델로 되돌리면 원래 설정한 온도가 자동 복구됩니다. 최소 롤백은 이번 LLM 파라미터 적응 변경을 되돌리는 것입니다.
# LLM_TEMPERATURE=0.7

# LLM 사용량 텔레메트리 message HMAC 설정(선택)
# 기본으로 비워두면 시스템이 데이터 디렉터리에 .llm_usage_hmac_secret을 생성해 로컬 배포 안에서 안정적으로 비교합니다.
# 배포 간 usage message HMAC 비교가 필요할 때만 같은 랜덤 키를 명시적으로 설정하세요. 교체 시 버전 태그도 함께 업데이트하세요.
# 명시적으로 설정할 때는 고엔트로피 랜덤값(예: openssl rand -hex 32)을 사용하고 실제 키를 버전 관리에 커밋하지 마세요.
# LLM_USAGE_HMAC_SECRET=
# LLM_USAGE_HMAC_KEY_VERSION=local-v1

# Provider prompt cache 설정(선택)
# TELEMETRY는 provider cache usage / diagnostics 기록만 제어하며 provider implicit cache는 제어하지 않습니다.
# HINTS는 prompt_cache_key, cache_control, user_id 같은 검증된 provider-specific hint를 능동 전송할지 제어합니다. 기본은 꺼짐입니다.
# DIAGNOSTICS_LEVEL은 off/basic/debug 중 선택합니다. debug도 탈민감 진단만 출력하며 raw prompt나 request body는 기록하지 않습니다.
# LLM_PROMPT_CACHE_TELEMETRY_ENABLED=true
# LLM_PROMPT_CACHE_HINTS_ENABLED=false
# LLM_PROMPT_CACHE_DIAGNOSTICS_LEVEL=off

# --- 다중 채널 설정(선택, Web 설정 화면에서도 가능) ---
# 각 채널은 base_url / api_key / models를 독립적으로 설정하며, 다중 Key 라운드로빈과 자동 fallback을 지원합니다.
#
# 예시: DeepSeek + Gemini 이중 채널
# LLM_CHANNELS=deepseek,gemini
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LLM_GEMINI_API_KEYS=key1,key2
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview
#
# 예시: 사용자 지정 API 엔드포인트(서드파티 프록시 / 통합 플랫폼 / 중계 서버)
# LLM_CHANNELS=my_proxy
# LLM_MY_PROXY_BASE_URL=https://your-proxy.example.com/v1
# LLM_MY_PROXY_API_KEY=sk-xxx
# LLM_MY_PROXY_MODELS=gpt-5.5,claude-sonnet-4-6
# LLM_MY_PROXY_PROTOCOL=openai
#
# 예시: Ollama 로컬 모델(API Key 불필요)
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b,llama3.2
#
# 자주 쓰는 공급자 템플릿(하나를 골라 .env에 복사. 전체 설명은 docs/llm-providers.md 참고)
#
# Anspire Open(검색과 LLM Key 공유, OpenAI Compatible)
# LLM_CHANNELS=anspire
# LLM_ANSPIRE_PROTOCOL=openai
# LLM_ANSPIRE_BASE_URL=https://open-gateway.anspire.cn/v6(예시)
# LLM_ANSPIRE_API_KEY=sk-xxx
# LLM_ANSPIRE_MODELS=Doubao-Seed-2.0-lite,Doubao-Seed-2.0-pro(예시 모델)
# LITELLM_MODEL=openai/Doubao-Seed-2.0-lite(예시)
#
# AIHubmix 통합 플랫폼(OpenAI Compatible)
# LLM_CHANNELS=aihubmix
# LLM_AIHUBMIX_PROTOCOL=openai
# LLM_AIHUBMIX_BASE_URL=https://aihubmix.com/v1
# LLM_AIHUBMIX_API_KEY=sk-xxx
# LLM_AIHUBMIX_MODELS=gpt-5.5,claude-sonnet-4-6,gemini-3.1-pro-preview
# LITELLM_MODEL=openai/gpt-5.5
#
# OpenAI 공식
# LLM_CHANNELS=openai
# LLM_OPENAI_PROTOCOL=openai
# LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_OPENAI_API_KEY=sk-xxx
# LLM_OPENAI_MODELS=gpt-5.5,gpt-5.4-mini
# LITELLM_MODEL=openai/gpt-5.5
#
# DeepSeek 공식
# LLM_CHANNELS=deepseek
# LLM_DEEPSEEK_PROTOCOL=deepseek
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LITELLM_MODEL=deepseek/deepseek-v4-flash
#
# Gemini 공식(공식 프로토콜, Base URL 비움)
# LLM_CHANNELS=gemini
# LLM_GEMINI_PROTOCOL=gemini
# LLM_GEMINI_API_KEY=xxx
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview,gemini-3-flash-preview
# LITELLM_MODEL=gemini/gemini-3.1-pro-preview
#
# Anthropic Claude 공식(공식 프로토콜, Base URL 비움)
# LLM_CHANNELS=anthropic
# LLM_ANTHROPIC_PROTOCOL=anthropic
# LLM_ANTHROPIC_API_KEY=sk-ant-xxx
# LLM_ANTHROPIC_MODELS=claude-sonnet-4-6,claude-opus-4-7
# LITELLM_MODEL=anthropic/claude-sonnet-4-6
#
# Kimi / Moonshot(OpenAI Compatible)
# LLM_CHANNELS=moonshot
# LLM_MOONSHOT_PROTOCOL=openai
# LLM_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# LLM_MOONSHOT_API_KEY=sk-xxx
# LLM_MOONSHOT_MODELS=kimi-k2.6,kimi-k2.5
# LITELLM_MODEL=openai/kimi-k2.6
#
# Qwen DashScope(OpenAI Compatible)
# LLM_CHANNELS=dashscope
# LLM_DASHSCOPE_PROTOCOL=openai
# LLM_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_DASHSCOPE_API_KEY=sk-xxx
# LLM_DASHSCOPE_MODELS=qwen3.6-plus,qwen3.6-flash
# LITELLM_MODEL=openai/qwen3.6-plus
#
# Zhipu GLM(OpenAI Compatible)
# LLM_CHANNELS=zhipu
# LLM_ZHIPU_PROTOCOL=openai
# LLM_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_ZHIPU_API_KEY=xxx
# LLM_ZHIPU_MODELS=glm-5.1,glm-4.7-flash
# LITELLM_MODEL=openai/glm-5.1
#
# MiniMax(OpenAI Compatible)
# 출처: 공식 OpenAI API 호환 문서 https://platform.minimax.io/docs/api-reference/text-chat
# LiteLLM은 openai/<model>을 통해 Chat Completions 호환 Base URL로 라우팅합니다.
# LLM_CHANNELS=minimax
# LLM_MINIMAX_PROTOCOL=openai
# LLM_MINIMAX_BASE_URL=https://api.minimax.io/v1
# LLM_MINIMAX_API_KEY=xxx
# LLM_MINIMAX_MODELS=MiniMax-M2.7,MiniMax-M2.7-highspeed
# LITELLM_MODEL=openai/MiniMax-M2.7
#
# Xiaomi MiMo(OpenAI Compatible)
# Base URL과 모델명은 MiMo 공식 문서/콘솔을 기준으로 하세요.
# LLM_CHANNELS=mimo
# LLM_MIMO_PROTOCOL=openai
# LLM_MIMO_BASE_URL=
# LLM_MIMO_API_KEY=sk-xxx
# LLM_MIMO_MODELS=mimo-xxx
# LITELLM_MODEL=openai/mimo-xxx
# 참고: 저장소 기본 daily_analysis workflow는 LLM_MIMO_*를 명시적으로 전달하지 않습니다. 이 예시는 기본적으로 로컬 .env, Docker 또는 자체 호스팅 스크립트용입니다. Actions에서 쓰려면 workflow 매핑도 함께 보완하세요.
#
# Volcengine Ark / Doubao(OpenAI Compatible, 실제 개통 지역에 맞춰 endpoint 조정)
# 출처: Volcengine Ark 온라인 추론 / Responses API 문서 https://www.volcengine.com/docs/82379/2121998
# LiteLLM은 openai/<model>을 통해 Chat Completions 호환 Base URL로 라우팅합니다.
# LLM_CHANNELS=volcengine
# LLM_VOLCENGINE_PROTOCOL=openai
# LLM_VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_VOLCENGINE_API_KEY=xxx
# LLM_VOLCENGINE_MODELS=doubao-seed-1-6-251015,doubao-seed-1-6-thinking-251015
# LITELLM_MODEL=openai/doubao-seed-1-6-251015
#
# SiliconFlow(OpenAI Compatible)
# 출처: 공식 모델 목록 https://docs.siliconflow.cn/quickstart/models
# LLM_CHANNELS=siliconflow
# LLM_SILICONFLOW_PROTOCOL=openai
# LLM_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# LLM_SILICONFLOW_API_KEY=sk-xxx
# LLM_SILICONFLOW_MODELS=deepseek-ai/DeepSeek-V3.2,Qwen/Qwen3-235B-A22B-Thinking-2507
# LITELLM_MODEL=openai/deepseek-ai/DeepSeek-V3.2
#
# OpenRouter(OpenAI Compatible)
# 출처: 공식 Models API https://openrouter.ai/docs/api/api-reference/models/get-models
# LLM_CHANNELS=openrouter
# LLM_OPENROUTER_PROTOCOL=openai
# LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_OPENROUTER_API_KEY=sk-or-xxx
# LLM_OPENROUTER_MODELS=~anthropic/claude-sonnet-latest,~openai/gpt-latest
# LITELLM_MODEL=openai/~anthropic/claude-sonnet-latest

# 고급: 모델 라우팅 YAML 설정(선택, docs/examples/litellm_config.example.yaml 참고)
# LITELLM_CONFIG=./litellm_config.yaml

# ===================================
# 검색 엔진 설정(주식 뉴스 수집용)
# ===================================
# Bocha API Keys(중국어 검색 최적화, AI 요약 지원, 여러 개는 쉼표로 구분)
# 발급: https://open.bocha.cn/
# BOCHA_API_KEYS=your_bocha_key_here
# MiniMax API Key(Coding Plan Web Search, 여러 개는 쉼표로 구분)
# 발급: https://platform.minimax.io/
# MINIMAX_API_KEYS=your_minimax_key_here
# Tavily API Keys(여러 개는 쉼표로 구분)
TAVILY_API_KEYS=
# SerpAPI Keys(여러 개는 쉼표로 구분)
SERPAPI_API_KEYS=
# Brave Search API Keys(여러 개는 쉼표로 구분)
# 발급: https://brave.com/search/api/
BRAVE_API_KEYS=
# SearXNG 인스턴스 주소(쉼표 구분, 자체 배포는 할당량 없음. settings.yml에서 format: json 활성화 필요)
# GitHub Actions 일일 분석 workflow는 같은 이름의 Variables를 우선하고 Secrets로 fallback합니다. 공개 주소는 Variable로 설정할 수 있습니다.
# 비워두면 기본적으로 searx.space에서 공개 인스턴스를 자동 가져옵니다. 공개 인스턴스 접근을 원하지 않으면 아래 스위치를 false로 두세요.
SEARXNG_BASE_URLS=
SEARXNG_PUBLIC_INSTANCES_ENABLED=true

# ===================================
# Social Sentiment Intelligence (US stocks only)
# ===================================
# Reddit / X (Twitter) / Polymarket sentiment data from api.adanos.org
# Only activates for US stock tickers (AAPL, TSLA, etc.), ignored for A-shares/HK stocks
# Free tier: 250 requests/month | Register: https://api.adanos.org
# SOCIAL_SENTIMENT_API_KEY=sk_live_your_key_here
# SOCIAL_SENTIMENT_API_URL=https://api.adanos.org

# ===================================
# 뉴스 시의성과 분석 필터 설정
# ===================================
# 뉴스 전략 기간: ultra_short(1일) / short(3일) / medium(7일) / long(30일)
# 실제 기간 = min(전략 기간, NEWS_MAX_AGE_DAYS)
# NEWS_STRATEGY_PROFILE=short
# 뉴스 최대 시의성(일). 검색 결과를 최근으로 제한해 오래된 정보를 피합니다.
# NEWS_MAX_AGE_DAYS=3
# 로컬 뉴스/정보 풀 보관 일수. intelligence_items 정보 풀만 정리하며 히스토리 리포트에는 영향이 없습니다.
# NEWS_INTEL_RETENTION_DAYS=30
# 단일 RSS/Atom 정보 소스 가져오기 제한 시간(초)
# NEWS_INTEL_FETCH_TIMEOUT_SEC=8
# 한 번에 각 정보 소스에서 최대 수집할 항목 수
# NEWS_INTEL_MAX_ITEMS_PER_SOURCE=50
# NewsNow HTTP API 기본 주소 - 외부 의존성 설정
# - 공식 프로젝트 및 배포 가이드: https://github.com/qqhann/newsnow
# - 현재 기본값 https://newsnow.busiyi.world 는 공개 예시 인스턴스이며 다음 위험이 있습니다.
#   * 공식 유지보수나 제한으로 사용할 수 없을 수 있음
#   * 안정성이나 데이터 신뢰성을 보장하지 않으며 데모와 테스트용임
# - 운영 환경에서는 제어 가능성과 안정성을 위해 자체 NewsNow 인스턴스 사용을 강하게 권장합니다.
# - 배포 전 API 계약 호환성을 검증하는 것을 권장합니다(docs/intelligence-sources.md 참고):
#   curl -sS "https://newsnow.busiyi.world/api/s?id=cls-hot" | python -c "import sys, json; data=json.load(sys.stdin); assert isinstance(data.get('items'), list)"
# - 이 설정은 정보 소스 수집과 정리 동작만 제어하며 LLM / provider / base URL / 호환 fallback 의미를 바꾸지 않습니다.
# NEWSNOW_BASE_URL=https://newsnow.busiyi.world
# 이격도 임계값(%). MA5와의 괴리가 이 값을 넘으면 추격 매수를 경고합니다. 강한 추세 종목은 자동으로 1.5배 완화됩니다.
# BIAS_THRESHOLD=5.0

# ===================================
# Agent 전략 대화 설정(Web 대화 페이지)
# ===================================
# Agent 전략 대화 활성화(기본 false, 내부 명칭은 skill로 통일)
# AGENT_MODE=true
# Agent 주 모델(선택): 비워두면 주 모델을 상속합니다. provider 접두사가 없으면 openai/<model>로 해석합니다.
# AGENT_LITELLM_MODEL=
# Agent 최대 추론 단계 상한(기본 10이면 각 하위 Agent가 자체 preset으로 실행. 기본 10보다 크면 모든 하위 Agent가 이 값을 사용. 특정 하위 Agent 기본값보다 작으면 상한으로 제한)
# AGENT_MAX_STEPS=10
# 기본 활성화 전략(쉼표 구분). 설정하지 않으면 아래 내장 기본값을 사용합니다.
#
# 내장 전략 skill 목록(자유롭게 조합 가능):
#   bull_trend          - 상승 추세(MA5>MA10>MA20 배열 + 낮은 이격도)
#   ma_golden_cross     - 이동평균 골든크로스(MA5가 MA10/MA20 상향 돌파)
#   volume_breakout     - 거래량 동반 돌파(가격이 최근 고점 돌파 + 거래량 증가)
#   hot_theme           - 인기 테마(정책/산업 이슈, 섹터 확산과 종목 관련성)
#   event_driven        - 이벤트 드리븐(실적, 정책, 수주, M&A 등 촉매)
#   growth_quality      - 성장 품질(매출/이익, ROE, 현금흐름과 지속 성장성)
#   expectation_repricing - 기대 재평가(실적/정책/밸류에이션 기대 차이의 회복 또는 실패)
#   shrink_pullback     - 거래량 감소 눌림(이평선 눌림 + 거래량 위축, 저가 매수 지점)
#   bottom_volume       - 바닥 거래량 증가(거래량 바닥 후 가격 바닥, 반전 신호)
#   dragon_head         - 주도주 전략(강한 주도주, 추세 지속 추격)
#   one_yang_three_yin  - 양봉 하나와 음봉 셋(세력 털기 후 강한 반전 패턴)
#   box_oscillation     - 박스권 진동(구간 고점 매도/저점 매수)
#   chan_theory         - Chan 이론(필/선분/중추)
#   wave_theory         - 파동 이론(엘리엇 파동 카운트)
#   emotion_cycle       - 심리 사이클(시장 심리 고저점 순환)
#
# 비워두면 시스템이 metadata에 선언된 기본 주 전략 skill을 사용합니다(내장 기본값은 bull_trend).
# AGENT_SKILLS=
#
# 전략 묶음을 직접 지정할 수도 있습니다.
# AGENT_SKILLS=bull_trend,ma_golden_cross,shrink_pullback
#
# 모든 내장 전략 활성화(두 방식은 동일):
# AGENT_SKILLS=all
# AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout,hot_theme,event_driven,growth_quality,expectation_repricing,shrink_pullback,bottom_volume,dragon_head,one_yang_three_yin,box_oscillation,chan_theory,wave_theory,emotion_cycle
#
AGENT_SKILLS=
# 사용자 지정 전략 디렉터리(선택, 사용자 YAML 전략 파일 배치. 환경변수명은 내부 skill 명칭을 따름)
# AGENT_SKILL_DIR=./strategies

# Agent 아키텍처 모드(기본 single, multi는 다중 Agent 오케스트레이션 모드)
# AGENT_ARCH=single

# Multi-Agent 오케스트레이션 모드(AGENT_ARCH=multi일 때만 유효)
# quick: 기술 분석 -> 의사결정(가장 빠름, 약 2회 LLM 호출)
# standard: 기술 -> 정보 -> 의사결정(기본)
# full: 기술 -> 정보 -> 리스크 관리 -> 의사결정
# specialist: 기술 -> 정보 -> 리스크 관리 -> 전략 전문가 평가 -> 의사결정
# AGENT_ORCHESTRATOR_MODE=standard

# Agent 실행 제한 시간 예산(초, 0은 비활성화. single-agent는 전체 루프 예산, multi-agent는 협업 오케스트레이션 예산. 기본 600)
# AGENT_ORCHESTRATOR_TIMEOUT_S=600

# 리스크 관리 Agent가 매수 신호를 거부할 수 있는지 여부(기본 켜짐)
# AGENT_RISK_OVERRIDE=true

# 메모리와 보정 시스템(과거 정확도를 추적해 신뢰도를 자동 조정)
# AGENT_MEMORY_ENABLED=false

# 백테스트 성과에 따라 전략 의견 자동 가중
# AGENT_SKILL_AUTOWEIGHT=true

# 전략 라우팅 모드(auto=시장 상태에 따라 자동 선택 / manual=AGENT_SKILLS 목록 사용)
# AGENT_SKILL_ROUTING=auto

# 종목 질문의 보이는 대화 컨텍스트 압축(기본 꺼짐). 켜면 사용자에게 보이는 user/assistant 히스토리만 압축하며 같은 턴의 tool/thinking 전달에는 영향이 없습니다.
# AGENT_CONTEXT_COMPRESSION_ENABLED=false
# 압축 전략: cost=토큰 절약 우선 / balanced=균형 / long_context_raw_first=원문 보존 우선
# AGENT_CONTEXT_COMPRESSION_PROFILE=balanced
# 압축을 트리거할 히스토리 token 임계값. 비워두면 현재 profile preset을 따릅니다.
# AGENT_CONTEXT_COMPRESSION_TRIGGER_TOKENS=
# 압축 시 최근 N개 사용자 턴과 그 뒤 응답은 원문 유지. 비워두면 현재 profile preset을 따릅니다.
# AGENT_CONTEXT_PROTECTED_TURNS=

# 이벤트 알림 모니터링(schedule 모드 백그라운드 폴링. 트리거 후 설정된 알림 채널 재사용)
# 호환성 설명: 이 섹션은 알림 규칙 설정만 추가하며 모델명, provider, Base URL, LiteLLM 또는 LLM 설정 의미를 바꾸지 않습니다. 되돌리려면 이벤트 모니터링 설정만 끄거나 제거하면 됩니다.
# legacy JSON은 single-symbol 기본 규칙 3종만 지원합니다. 기술 지표, 관심종목, 보유/계좌, 시장 신호등 규칙은 Web/API 알림 센터에서 설정하세요.
# legacy JSON 지원 규칙:
#   price_cross          - 가격 임계값 돌파, direction: above / below, 필드: price
#   price_change_percent - 등락률 임계값, direction: up / down, 필드: change_pct(단위: %)
#   volume_spike         - 거래량 증가, 필드: multiplier(최근 20일 평균 거래량 대비 배수)
# AGENT_EVENT_MONITOR_ENABLED=false
# AGENT_EVENT_MONITOR_INTERVAL_MINUTES=5
# AGENT_EVENT_ALERT_RULES_JSON=[{"stock_code":"600519","alert_type":"price_cross","direction":"above","price":1800},{"stock_code":"300750","alert_type":"price_change_percent","direction":"down","change_pct":3.0},{"stock_code":"000858","alert_type":"volume_spike","multiplier":2.5}]

# ===================================
# 알림 채널 설정(여러 개를 동시에 설정하면 모두 발송)
# ===================================
#
# [방식 1] WeCom 로봇
# WeCom 그룹 -> 설정 -> 그룹 로봇 -> 추가 -> Webhook 주소 복사
#
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here
#
# [방식 2] Feishu 로봇(둘 중 하나)
#
# 방식 2a - 그룹 사용자 지정 로봇 Webhook
# Feishu 그룹 -> 설정 -> 그룹 로봇 -> 로봇 추가 -> 사용자 지정 로봇 -> Webhook 주소 복사
#
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_key_here
# 로봇 보안 설정에서 "서명 검증"을 켰다면 secret도 함께 입력해야 합니다.
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# 로봇 보안 설정에서 "키워드"를 켰다면 같은 키워드를 입력해야 합니다. 시스템이 각 메시지 앞에 자동으로 붙입니다.
# FEISHU_WEBHOOK_KEYWORD=주식일보
#
# 방식 2b - Feishu 앱 로봇(App Bot) 푸시
# Feishu 오픈 플랫폼에서 앱을 만들고 im:message 권한을 켠 뒤 배포하세요.
#
# 그룹 채팅 모드(권장): 로봇을 대상 그룹에 초대한 뒤 그룹 설정에서 chat_id를 가져옵니다.
# FEISHU_APP_ID=cli_xxxxxxxxxxxxx
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=chat_id
#
# 개인 채팅 모드: 지정 사용자에게 직접 DM을 보냅니다. 사용자의 open_id는 로봇 이벤트 또는 연락처 API에서 가져옵니다.
# FEISHU_APP_ID=cli_xxxxxxxxxxxxx
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_CHAT_ID=ou_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=open_id
# FEISHU_DOMAIN=feishu  # 도메인: feishu(중국 내 Feishu) / lark(국제판 larksuite.com)
#
# [방식 3] Telegram 로봇(두 항목 모두 필요)
# 1. Telegram에서 @BotFather 찾기 -> /newbot -> Bot Token 발급
# 2. Chat ID 가져오기: @userinfobot에게 메시지를 보내거나 https://api.telegram.org/bot<token>/getUpdates 방문
#
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_MESSAGE_THREAD_ID=2780
#
# [방식 4] 이메일 푸시(2개 설정만 필요, SMTP 자동 인식)
# QQ Mail, 163 Mail, Gmail 등 SMTP 앱 비밀번호/기본 인증을 지원하는 메일함을 지원합니다.
# Outlook / Exchange에서 테넌트가 OAuth2를 강제하면 현재 버전은 아직 지원하지 않습니다.
# 1. 앱 비밀번호 발급(QQ Mail 예시): 설정 -> 계정 -> POP3/SMTP 서비스 -> 켜기 -> 앱 비밀번호 발급
# 2. 아래 두 항목만 입력하면 됩니다.
#
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_RECEIVERS=receiver@example.com  # 선택, 비워두면 자기 자신에게 발송
#
# [방식 4 확장] 주식 그룹별로 다른 이메일에 발송(Issue #268, 선택)
# STOCK_LIST가 실제 분석 범위를 결정합니다. STOCK_GROUP_N은 메일 수신자만 결정하므로 항상 STOCK_LIST의 부분집합으로 쓰는 것을 권장합니다.
# Telegram / WeCom / Webhook 등 다른 채널은 여전히 전체 STOCK_LIST 기준으로 발송되며 그룹 때문에 분리되지 않습니다.
# 현재 저장소 기본 GitHub Actions daily_analysis workflow는 임의 번호의 STOCK_GROUP_N / EMAIL_GROUP_N을 자동 주입하지 않습니다.
# 따라서 이 기능은 로컬 .env, Docker 또는 해당 변수를 명시적으로 주입한 다른 실행 환경에서 사용하세요.
# STOCK_GROUP_1=600519,300750
# EMAIL_GROUP_1=user1@example.com
# STOCK_GROUP_2=002594,AAPL
# EMAIL_GROUP_2=user2@example.com
#
# [방식 5] 사용자 지정 Webhook(여러 개는 쉼표로 구분)
# DingTalk, Discord, Slack, Bark, 자체 서비스 등 POST JSON을 지원하는 임의 Webhook에 사용합니다.
# 시스템이 일반적인 서비스를 자동 인식해 해당 형식을 사용합니다.
#
# CUSTOM_WEBHOOK_URLS=https://oapi.dingtalk.com/robot/send?access_token=xxx,https://hooks.slack.com/services/xxx
# CUSTOM_WEBHOOK_BEARER_TOKEN=  # 선택, 인증이 필요한 Webhook에 사용(Header Authorization: Bearer <token>)
# CUSTOM_WEBHOOK_BODY_TEMPLATE=  # 선택, 전역 JSON body 템플릿. Bark/Slack/Discord 등 자동 payload를 덮어씀. $content_json/$title_json 권장
# Docker Compose에서 .env를 직접 작성할 때는 $$content_json/$$title_json으로 쓰세요. Web 설정 화면은 자동 이스케이프하며 런타임에는 다시 단일 $로 복원됩니다.
# WEBHOOK_VERIFY_SSL=true   # 기본 검증. 이 설정을 읽는 webhook-style HTTPS 알림 요청에 영향. false로 두면 자체 서명 인증서를 지원합니다. 경고: 비활성화 시 MITM 위험이 있으니 신뢰할 수 있는 내부망에서만 사용하세요.
#
# [방식 6] Pushover 설정
# Pushover 계정을 등록하고 앱 Token을 생성하세요. https://pushover.net/apps/build
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=
#
# [방식 6 확장] ntfy 설정
# NTFY_URL에는 topic path가 포함되어야 합니다. 예: https://ntfy.sh/my-topic 또는 https://self-hosted:port/my-topic
# 시스템이 topic을 파싱하고 ntfy JSON publish API로 Markdown 텍스트를 보냅니다.
# NTFY_URL=
# NTFY_TOKEN=  # 선택, Bearer Token이 필요한 topic 또는 자체 ntfy server에 사용
#
# [방식 6 확장] Gotify 설정
# GOTIFY_URL은 Gotify server base URL이며 /message를 포함하지 않습니다. 시스템이 /message를 붙이고 X-Gotify-Key Header로 token을 보냅니다.
# GOTIFY_URL=
# GOTIFY_TOKEN=  # Gotify application token
#
# [방식 7] PushPlus 설정(중국 푸시 서비스, 권장)
# PushPlus 계정을 등록하고 Token을 발급받으세요. https://www.pushplus.plus
# PUSHPLUS_TOKEN=
# 그룹 푸시: 그룹 코드를 입력하면 그룹의 모든 구독 사용자에게 메시지를 보냅니다(일대다).
# PUSHPLUS_TOPIC=
#
# [방식 8] Discord 설정
# Webhook(권장, 설정 간단)과 Bot API(권한 높음) 두 방식을 지원합니다.
# 
# 방식 1: Discord Webhook(권장, Bot 계정 불필요)
# Discord 채널 설정 -> 연동 -> Webhook -> 새 Webhook -> URL 복사
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
# 
# 방식 2: Discord Bot API(Bot 계정과 채널 ID 필요)
# 1. Bot 생성: https://discord.com/developers/applications -> 새 애플리케이션 -> Bot -> Bot 생성
# 2. Bot Token 발급: Bot 페이지 -> Token 재설정
# 3. 채널 ID 가져오기: Discord 개발자 모드 켜기 -> 채널 우클릭 -> ID 복사
# DISCORD_BOT_TOKEN=
# DISCORD_MAIN_CHANNEL_ID=
# DISCORD_CHANNEL_ID=   # 기존 변수명 호환, DISCORD_MAIN_CHANNEL_ID 사용 권장
# Discord Interaction / Webhook 콜백을 받으려면 서명 검증용 공개키를 반드시 설정해야 합니다.
# 발급 위치: Discord Developer Portal -> General Information -> Public Key
# DISCORD_INTERACTIONS_PUBLIC_KEY=
# 
# [방식 9] Slack 설정
# Bot API(권장)와 Incoming Webhook 두 방식을 지원합니다.
# 동시에 설정하면 Bot API를 우선 사용해 텍스트와 이미지를 같은 채널로 보냅니다.
#
# 방식 1: Slack Bot API(권장, 이미지 업로드 지원)
# 1. Slack App 생성: https://api.slack.com/apps -> Create New App
# 2. Bot Token Scopes 추가: chat:write, files:write
# 3. 워크스페이스에 설치하고 Bot Token(xoxb-...) 발급
# 4. 채널 ID 가져오기: 채널 상세 -> 하단에서 채널 ID 복사
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C01234567
#
# 방식 2: Slack Incoming Webhook(설정 간단, 이미지 업로드 미지원)
# Slack App 관리 페이지에서 Incoming Webhook 생성 -> URL 복사
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
#
# [방식 10] ServerChan3 설정(중국 푸시 서비스, WeChat 푸시 지원)
# ServerChan3 계정을 등록하고 SendKey를 발급받으세요. https://sc3.ft07.com/
# SERVERCHAN3_SENDKEY=
#
# [방식 11] AstrBot 설정
# ASTRBOT_URL=
# ASTRBOT_TOKEN=  # 선택, Bearer Token이 필요한 AstrBot Webhook에 사용
#
# [고급 설정] 메시지 길이 제한(바이트)
# 제한을 넘으면 자동으로 나눠 보내며 보통 수정할 필요가 없습니다.
# FEISHU_MAX_BYTES=20000    # Feishu 제한 약 20KB, 기본 20000 바이트
# WECHAT_MAX_BYTES=4000     # WeCom 제한 4096 바이트, 기본 4000 바이트
#
# [Markdown을 이미지로 변환](Issue #455)
# Markdown을 지원하지 않는 채널에는 리포트를 이미지로 변환해 보내 가독성을 높입니다.
# 단일 종목 푸시 + 이미지: MARKDOWN_TO_IMAGE_CHANNELS 설정과 변환 도구 설치가 모두 필요합니다.
# MARKDOWN_TO_IMAGE_CHANNELS=telegram,wechat,custom,email,slack   # 쉼표 구분
# MARKDOWN_TO_IMAGE_MAX_CHARS=15000   # 이 길이를 넘으면 초대형 이미지를 피하기 위해 변환하지 않음
# MD2IMG_ENGINE=wkhtmltoimage   # wkhtmltoimage(기본) | markdown-to-file(emoji가 더 좋음, npm i -g markdown-to-file 필요)
# 이미지 변환 도구: wkhtmltopdf (apt install wkhtmltopdf / brew install wkhtmltopdf) 또는 markdown-to-file
#
# [알림 라우팅 전략](Issue #1200 P3)
# 기본은 비움: 해당 유형의 알림을 설정된 모든 채널로 보냅니다. 값을 입력하면 나열된 설정 채널로만 보냅니다.
# 허용 값: wechat,feishu,telegram,email,pushover,ntfy,gotify,pushplus,serverchan3,custom,discord,slack,astrbot
# NOTIFICATION_REPORT_CHANNELS=
# NOTIFICATION_ALERT_CHANNELS=
# NOTIFICATION_SYSTEM_ERROR_CHANNELS=
#
# [알림 노이즈 감소](Issue #1200 P4)
# 기본은 모두 꺼짐. 정적 알림 채널에만 영향이 있고 로봇이 트리거한 대화 응답에는 영향이 없습니다.
# NOTIFICATION_DEDUP_TTL_SECONDS=0      # 같은 안정 dedup key는 TTL 안에서 한 번만 발송. 0은 꺼짐
# NOTIFICATION_COOLDOWN_SECONDS=0       # 같은 cooldown key는 기간 안에서 빈도 제한. 0은 꺼짐
# NOTIFICATION_QUIET_HOURS=             # 조용한 시간대, 형식 HH:MM-HH:MM, 자정 넘김 지원
# NOTIFICATION_TIMEZONE=                # 조용한 시간대의 타임존, 예: Asia/Shanghai. 비워두면 TZ/시스템 로컬 타임존 사용
# NOTIFICATION_MIN_SEVERITY=            # info,warning,error,critical. 비워두면 현 상태 유지
# NOTIFICATION_DAILY_DIGEST_ENABLED=false  # 예약 설정. 현재는 일일 요약을 보내지 않음
#
# [실시간 시세 사전 조회](Issue #455)
# PREFETCH_REALTIME_QUOTES=true   # false로 두면 비활성화해 efinance/akshare_em의 전체 시장 조회를 피합니다. tushare는 단일 종목 인터페이스라 사전 조회 시 첫 종목만 가져옵니다.

# ===================================
# 단일 종목 푸시 설정(선택)
# ===================================
# 단일 종목 푸시 모드: 전체 요약 후 보내는 대신 종목 하나를 분석할 때마다 즉시 보냅니다.
# SINGLE_STOCK_NOTIFY=false
#
# 리포트 유형: simple(간단), full(전체), brief(3-5문장 요약)
# Docker 환경에서 푸시 내용이 누락되면 full로 설정할 수 있습니다.
# REPORT_TYPE=simple
# 리포트 출력 언어: zh(중국어, 기본) / en(영어)
# REPORT_LANGUAGE=zh
# 분석 결과 요약만: true로 두면 종목 상세 없이 요약만 푸시합니다.
# REPORT_SUMMARY_ONLY=false
# 알림 리포트 하단에 이번 분석에 사용한 LLM 모델명을 표시합니다. false로 두면 숨깁니다.
# REPORT_SHOW_LLM_MODEL=true
#
# Report Engine P0 (Jinja2 / 무결성 검증 / 히스토리 비교)
# REPORT_TEMPLATES_DIR=templates
# REPORT_RENDERER_ENABLED=false
# REPORT_INTEGRITY_ENABLED=true
# REPORT_INTEGRITY_RETRY=1
# REPORT_HISTORY_COMPARE_N=0

# 종목 분석과 시장 리뷰를 합쳐 푸시(기본 false). 이메일 수를 줄이고 스팸 위험을 낮춥니다.
# MERGE_EMAIL_NOTIFICATION=false

# ===================================
# 분석 간격 설정(선택)
# ===================================
# 종목 분석과 시장 분석 사이 지연 시간(초)
# Gemini 등 AI API의 rate limit를 피하는 데 사용합니다.
# ANALYSIS_DELAY=0

# 앱 AppKey(Webhook 모드와 공용)
DINGTALK_APP_KEY=xxxx
# 앱 AppSecret(Webhook 모드와 공용)
DINGTALK_APP_SECRET=xxxx
# Stream 모드 활성화
DINGTALK_STREAM_ENABLED=false

# Feishu 앱 설정(App Bot 능동 푸시 / Stream Bot / 클라우드 문서용. 그룹 Webhook 푸시를 직접 켜지는 않음)
FEISHU_APP_ID=xxxx
FEISHU_APP_SECRET=xxxx  # App Bot 능동 푸시에는 FEISHU_CHAT_ID도 필요. 간단한 그룹 푸시는 FEISHU_WEBHOOK_URL 우선 사용
# App Bot 능동 푸시 대상. Stream Bot 또는 클라우드 문서에는 필요 없음
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=chat_id
# 장기 연결 모드 활성화
FEISHU_STREAM_ENABLED=false
# Feishu 그룹 로봇 Webhook 보안 설정(Webhook 푸시 모드에서만 사용)
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# FEISHU_WEBHOOK_KEYWORD=주식일보

# 데이터베이스 경로
DATABASE_PATH=./data/stock_analysis.db
# SQLite 쓰기 최적화: 파일 DB는 기본적으로 WAL을 켜서 대량 쓰기와 동시 쓰기 시 lock 경쟁을 줄입니다.
SQLITE_WAL_ENABLED=true
# SQLite lock 대기 시간 제한(밀리초)
SQLITE_BUSY_TIMEOUT_MS=5000
# SQLite에서 database is locked / database table is locked 발생 시 최대 재시도 횟수
SQLITE_WRITE_RETRY_MAX=3
# SQLite 쓰기 재시도 기본 backoff 시간(초, 지수 backoff로 증가)
SQLITE_WRITE_RETRY_BASE_DELAY=0.1

# 분석 히스토리 스냅샷: false로 두면 전체 context_snapshot을 영구 저장하지 않습니다.
# enhanced_context, market_phase_summary, AnalysisContextPack overview, diagnostics, raw snapshot 필드를 포함합니다.
SAVE_CONTEXT_SNAPSHOT=true

# ===================================
# 백테스트 설정(선택)
# ===================================
# 백테스트 활성화 여부(true/false)
BACKTEST_ENABLED=true
# 백테스트 평가 기간(거래일 수)
BACKTEST_EVAL_WINDOW_DAYS=10
# N일 전 분석 기록만 백테스트(당일/최근 데이터 불완전 회피)
BACKTEST_MIN_AGE_DAYS=14
# 백테스트 엔진 버전(백테스트 로직 업그레이드 시 결과 구분용)
BACKTEST_ENGINE_VERSION=v1
# 중립 구간 임계값(%). 예: 2는 -2%~+2%를 횡보로 간주
BACKTEST_NEUTRAL_BAND_PCT=2.0

# === 예약 작업 설정 ===
# 예약 작업 활성화 여부(true/false)
SCHEDULE_ENABLED=false
# 매일 실행 시간(HH:MM 형식, 24시간제)
SCHEDULE_TIME=18:00
# 여러 실행 시간 목록(쉼표 구분, 비워두면 SCHEDULE_TIME 사용)
SCHEDULE_TIMES=
# 예약 모드 시작 시 분석을 즉시 한 번 실행할지 여부(true/false)
# 명시적으로 설정하지 않으면 예약 모드는 기존 설정 호환을 위해 RUN_IMMEDIATELY의 런타임 override 의미를 따릅니다.
SCHEDULE_RUN_IMMEDIATELY=true
# 비예약 모드 시작 시 분석을 즉시 한 번 실행할지 여부(true/false)
RUN_IMMEDIATELY=true
# 시장 리뷰 활성화 여부(true/false)
MARKET_REVIEW_ENABLED=true
# 시장 환경 요약을 종목 분석 Prompt에 주입하고 보수적 가드레일을 켤지 여부(true/false, 기본 켜짐)
DAILY_MARKET_CONTEXT_ENABLED=true
# 시장 리뷰 대상 지역: cn(A주), hk(홍콩), us(미국), both(전체 시장). hk/us는 홍콩/미국 주식만 보는 사용자에게 적합
# MARKET_REVIEW_REGION=cn
# 시장 리뷰 지수 등락 색상: green_up=상승 초록/하락 빨강(기본), red_up=상승 빨강/하락 초록
# MARKET_REVIEW_COLOR_SCHEME=green_up

# ===================================
# 프록시 설정(선택)
# ===================================
# 프록시 활성화 여부(true/false, 기본 false)
# 로컬 개발 환경에서만 적용되며 GitHub Actions 환경에서는 자동으로 건너뜁니다.
USE_PROXY=false
# 프록시 서버 주소(기본 127.0.0.1)
PROXY_HOST=127.0.0.1
# 프록시 서버 포트(기본 10809)
PROXY_PORT=10809

# 시스템 설정
# 로그 디렉터리
LOG_DIR=./logs
# 로그 레벨(DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
# LiteLLM 내부 로그 레벨(DEBUG/INFO/WARNING/ERROR/CRITICAL, 기본 WARNING. 내부 스트리밍/라우팅 세부 문제를 볼 때 임시로 DEBUG 설정 가능)
# LITELLM_LOG_LEVEL=WARNING
# 최대 동시 스레드 수(차단 방지를 위해 낮은 동시성 권장)
MAX_WORKERS=3
# 디버그 로그 활성화 여부
DEBUG=false

# ===================================
# WebUI 설정(선택)
# ===================================
# 기본으로 WebUI를 시작할지 여부(true/false, 기본 false)
WEBUI_ENABLED=false
# WebUI listen 주소(기본 127.0.0.1. Docker/클라우드 서버에서 외부 접근하려면 0.0.0.0 필요. docs/deploy-webui-cloud.md 참고)
WEBUI_HOST=127.0.0.1
# WebUI listen 포트(기본 8000)
WEBUI_PORT=8000
# Web 서비스 시작 전 프론트엔드를 자동 빌드할지 여부(npm install && npm run build, 기본 true)
WEBUI_AUTO_BUILD=true
# 단일 계층 신뢰 프록시(예: Nginx -> App)에서 X-Forwarded-For를 신뢰해 실제 IP를 가져오고 가장 오른쪽 값을 로그인 rate limit에 사용합니다. 다중 프록시/CDN에서는 제한 key가 엣지 프록시 IP로 퇴화할 수 있어 추가 평가가 필요합니다. 인터넷 직결 시 위조 방지를 위해 false 유지
# TRUST_X_FORWARDED_FOR=false

# ===================================
# Web 로그인 인증(선택)
# ===================================
# true로 두면 비밀번호 보호를 켭니다. 최초 접속 시 웹에서 초기 비밀번호를 설정하고 "시스템 설정 > 비밀번호 변경"에서 수정할 수 있습니다.
# 비밀번호를 잊었으면 서버에서 실행: python -m src.auth reset_password
ADMIN_AUTH_ENABLED=false
# ADMIN_SESSION_MAX_AGE_HOURS=24  # Session 유효 기간(시간)

# ===========================================
# 이미지에서 종목 코드 인식(설정 페이지 "이미지에서 추가")
# ===========================================
# 단일 요청 제한 시간 60초, 이미지 최대 5MB
# GEMINI_API_KEY, ANTHROPIC_API_KEY, OPENAI_API_KEY 중 최소 하나(Vision 지원 모델)를 설정해야 합니다.

# ===========================================
# Data Fetcher Priority Configuration
# ===========================================
# Lower number = higher priority (tried first)
# Default priorities: efinance(0) > akshare(1) > tushare/pytdx(2) > baostock(3) > yfinance(4)
# For US stocks, set YFINANCE_PRIORITY=0 to use Yahoo Finance first

# EFINANCE_PRIORITY=0      # EastMoney (China) - default: 0
# EFINANCE_CALL_TIMEOUT=30 # Timeout (seconds) for efinance API calls; prevents indefinite hangs
#                          # when eastmoney hosts are unreachable. Default: 30
# AKSHARE_PRIORITY=1       # AkShare (China) - default: 1
# TUSHARE_PRIORITY=2       # Tushare Pro (China) - default: 2
# PYTDX_PRIORITY=2         # Tongdaxin (China) - default: 2
#
# Pytdx custom server (for intranet/deploy): use custom host instead of built-in public servers
# PYTDX_HOST=192.168.1.100
# PYTDX_PORT=7709
# Or multiple servers: PYTDX_SERVERS=ip1:port1,ip2:port2
# BAOSTOCK_PRIORITY=3      # Baostock (China) - default: 3
# YFINANCE_PRIORITY=4      # Yahoo Finance (Global) - default: 4

# Example: Prioritize Yahoo Finance for US stocks
# YFINANCE_PRIORITY=0
# EFINANCE_PRIORITY=99

# ===========================================
# 실시간 시세 데이터 소스 우선순위 설정
# ===========================================
# 거래량 비율, 회전율, PER 등 실시간 데이터를 가져오는 데 사용합니다.
# 선택 데이터 소스(쉼표 구분, 순서대로 시도):
#   - tencent: Tencent Finance, 거래량 비율/회전율/PE/PB 제공, 단일 종목 조회 안정적(우선 추천)
#   - akshare_sina: Sina Finance, 기본 시세, 거래량 비율 없음, 매우 안정적
#   - efinance: EastMoney(efinance 라이브러리), 거래량 비율 있음, 전체 조회는 차단되기 쉬움
#   - akshare_em: EastMoney(akshare 라이브러리), 데이터가 가장 많지만 전체 조회는 차단되기 쉬움
#   - tushare: Tushare Pro, 2000 포인트 필요, 데이터 포괄적(유료 사용자 추천)
#
# 기본 우선순위: tencent > akshare_sina > efinance > akshare_em
# Tushare Pro 고포인트 계정이 있으면 tushare를 첫 번째로 둘 수 있습니다.
# REALTIME_SOURCE_PRIORITY=tushare,tencent,akshare_sina,efinance,akshare_em
# REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em

# 실시간 시세 활성화 여부(끄면 과거 종가로 분석)
# ENABLE_REALTIME_QUOTE=true

# 장중 실시간 기술 지표: 켜면 실시간 가격으로 MA/상승 배열을 계산(Issue #234). 끄면 전일 종가 사용
# ENABLE_REALTIME_TECHNICAL_INDICATORS=true

# 매물대 분포 활성화 여부(이 인터페이스는 불안정하므로 클라우드 배포에서는 끄는 것을 권장)
# ENABLE_CHIP_DISTRIBUTION=true

# 기본면 집계 활성화 여부(신규 P0 기능)
# ENABLE_FUNDAMENTAL_PIPELINE=true

# 기본면 집계 성능/안정성 파라미터(단위: 초)
# FUNDAMENTAL_STAGE_TIMEOUT_SECONDS=8.0
# FUNDAMENTAL_FETCH_TIMEOUT_SECONDS=3.0
# FUNDAMENTAL_RETRY_MAX=1
# FUNDAMENTAL_CACHE_TTL_SECONDS=120
# FUNDAMENTAL_CACHE_MAX_ENTRIES=256

# ===========================================
# Portfolio P0: 가져오기 / 리스크 / 환율 degrade 설정
# ===========================================
# PORTFOLIO_RISK_CONCENTRATION_ALERT_PCT=35.0
# PORTFOLIO_RISK_DRAWDOWN_ALERT_PCT=15.0
# PORTFOLIO_RISK_STOP_LOSS_ALERT_PCT=10.0
# PORTFOLIO_RISK_STOP_LOSS_NEAR_RATIO=0.8
# PORTFOLIO_RISK_LOOKBACK_DAYS=180
# PORTFOLIO_FX_UPDATE_ENABLED=true

# EastMoney 인터페이스 패치: EastMoney/Efinance/Akshare EastMoney 인터페이스가 자주 실패(RemoteDisconnected, 연결 종료)할 때 켜는 것을 권장합니다.
# 켜면 NID 토큰과 랜덤 User-Agent를 주입해 EastMoney rate limit 가능성을 낮춥니다.
# ENABLE_EASTMONEY_PATCH=false
